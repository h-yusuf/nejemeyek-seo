---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';
import CategoryTabs from '../components/CategoryTabs.astro';
import ProductCard from '../components/ProductCard.astro';
import { getAllProducts, getCategories } from '../lib/db';

const db = Astro.locals.runtime.env.DB;
const waNumber = Astro.locals.runtime.env.WA_NUMBER || '';

const [products, categories] = await Promise.all([
  getAllProducts(db),
  getCategories(db),
]);
---

<BaseLayout
  title="Nejemeyek — Supplier & Produsen Peyek Jogja | Peyek Rebon, Kacang, Toples"
  description="Produsen dan supplier peyek khas Jogja. Peyek Rebon, Peyek Kacang, Peyek Toples, Peyek Tipis. Oleh-oleh dan cemilan khas Yogyakarta. Cocok untuk pecel Madiun. Pesan via WhatsApp, COD area Jogja."
  localBusiness={true}
>
  <!-- Header -->
  <header class="bg-white px-4 pt-5 pb-4">
    <div class="flex items-start justify-between gap-3">
      <div>
        <p class="text-stone-400 text-xs">Peyek Khas Jogja</p>
        <h1 class="text-2xl font-bold text-stone-900 mt-0.5">Nejemeyek</h1>
      </div>
      {waNumber && (
        <a
          href={`https://wa.me/${waNumber}?text=${encodeURIComponent('Halo Nejemeyek, saya mau tanya produk dan stok yang tersedia')}`}
          target="_blank"
          rel="noopener noreferrer"
          class="shrink-0 flex items-center gap-1.5 text-xs font-medium bg-green-50 hover:bg-green-100 border border-green-200 text-green-700 px-3 py-2 rounded-lg transition-colors mt-1"
        >
          <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.118.55 4.107 1.512 5.832L.057 23.999l6.304-1.654A11.95 11.95 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 0 1-5.007-1.371l-.36-.213-3.736.979.999-3.648-.233-.374A9.818 9.818 0 1 1 12 21.818z"/>
          </svg>
          Buka WA
        </a>
      )}
    </div>

    <!-- Search -->
    <div class="relative mt-4">
      <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-stone-400" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input
        type="text"
        id="search-input"
        placeholder="Cari menu..."
        autocomplete="off"
        class="w-full bg-stone-100 rounded-xl pl-9 pr-4 py-3 text-sm text-stone-900 placeholder-stone-400 outline-none focus:ring-2 focus:ring-stone-300"
      />
    </div>
  </header>

  <!-- Category tabs -->
  <CategoryTabs categories={categories} />

  <!-- Product grid -->
  <section class="px-3 py-3">
    <div id="product-grid" class="grid grid-cols-2 gap-3">
      {products.length === 0 ? (
        <div class="col-span-2 text-center py-16 text-stone-400">
          <p class="text-sm">Produk segera hadir...</p>
        </div>
      ) : (
        products.map(product => (
          <ProductCard product={product} waNumber={waNumber} />
        ))
      )}
    </div>
    <p id="empty-search" class="hidden text-center py-12 text-stone-400 text-sm col-span-2">
      Tidak ada produk yang cocok
    </p>
  </section>

  <footer class="border-t border-stone-200 mt-2">
    <div class="px-4 py-6 space-y-3">
      <h2 class="text-sm font-semibold text-stone-700">Tentang Nejemeyek</h2>
      <p class="text-xs text-stone-500 leading-relaxed">
        Nejemeyek adalah produsen dan supplier peyek khas Jogja yang berpusat di Yogyakarta.
        Kami menyediakan berbagai varian: <strong>Peyek Rebon</strong>, <strong>Peyek Kacang</strong>,
        <strong>Peyek Tipis</strong>, hingga <strong>Peyek Toples</strong> siap kirim.
        Cocok sebagai pelengkap <strong>pecel Madiun</strong> maupun
        <strong>oleh-oleh khas Jogja</strong> dan <strong>cemilan kekinian Yogyakarta</strong>.
      </p>
      <p class="text-xs text-stone-500 leading-relaxed">
        Sebagai <strong>pusat produksi peyek di Jogja</strong>, kami melayani pembelian satuan
        maupun partai besar untuk reseller dan supplier. Pengiriman GoSend, COD area Sleman &amp;
        Kota Yogyakarta, atau paket ke seluruh Indonesia.
      </p>
    </div>
    <p class="text-center text-stone-400 text-xs py-4 border-t border-stone-200">
      &copy; {new Date().getFullYear()} Nejemeyek — Peyek Khas Jogja
    </p>
  </footer>
</BaseLayout>

<script>
  let activeCat = 'semua';
  let searchText = '';

  function applyFilter() {
    const cards = document.querySelectorAll<HTMLElement>('[data-product-cat]');
    let visibleCount = 0;
    cards.forEach(card => {
      const catMatch = activeCat === 'semua' || card.dataset.productCat === activeCat;
      const nameMatch = !searchText || (card.dataset.productName ?? '').includes(searchText);
      const show = catMatch && nameMatch;
      card.style.display = show ? '' : 'none';
      if (show) visibleCount++;
    });
    const emptyMsg = document.getElementById('empty-search');
    if (emptyMsg) emptyMsg.style.display = visibleCount === 0 ? 'block' : 'none';
  }

  document.getElementById('search-input')?.addEventListener('input', e => {
    searchText = (e.target as HTMLInputElement).value.toLowerCase().trim();
    applyFilter();
  });

  document.addEventListener('cat:change', (e: Event) => {
    activeCat = (e as CustomEvent<string>).detail;
    applyFilter();
  });
</script>
