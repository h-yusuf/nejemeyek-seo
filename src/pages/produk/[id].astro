---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProductById } from '../../lib/db';
import { formatRupiah, buildWaOrderUrl } from '../../lib/wa';

export const prerender = false;

const { id } = Astro.params;
const db = Astro.locals.runtime.env.DB;
const waNumber = Astro.locals.runtime.env.WA_NUMBER;

const product = await getProductById(db, id);
if (!product) return Astro.redirect('/');

const waUrl = buildWaOrderUrl({ displayName: product.displayName, qty: 1, waNumber });
const isActive = product.is_active === 1;

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.displayName,
  image: product.image_url ?? '',
  brand: { '@type': 'Brand', name: 'Nejemeyek' },
  offers: {
    '@type': 'Offer',
    priceCurrency: 'IDR',
    price: product.price,
    availability: isActive
      ? 'https://schema.org/InStock'
      : 'https://schema.org/OutOfStock',
    seller: { '@type': 'Organization', name: 'Nejemeyek' },
  },
};
---

<BaseLayout
  title={`${product.displayName} — Peyek Khas Jogja | Nejemeyek`}
  description={`${product.displayName} peyek khas Jogja. Harga ${formatRupiah(product.price)}. Pesan via WhatsApp, kirim GoSend atau COD wilayah Yogyakarta.`}
  ogImage={product.image_url ?? undefined}
  productSchema={productSchema}
>
  <!-- Nav -->
  <nav class="bg-white border-b border-stone-100 px-4 py-4 flex items-center gap-2">
    <a href="/" class="text-stone-400 hover:text-stone-700 transition-colors flex items-center gap-1.5 text-sm">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M10 12L6 8l4-4"/>
      </svg>
      Kembali
    </a>
    <span class="text-stone-200 text-xs">|</span>
    <span class="text-stone-500 text-xs truncate">{product.category.name}</span>
  </nav>

  <!-- Image -->
  <div class="relative bg-stone-50 aspect-square w-full">
    {product.image_url ? (
      <img
        src={product.image_url}
        alt={product.displayName}
        class={`w-full h-full object-cover ${!isActive ? 'opacity-40' : ''}`}
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#d1d5db" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 2v4c0 1.1.9 2 2 2s2-.9 2-2V2M5 8v14M3 5h4"/>
          <path d="M21 2c-2.5 1-4 3.5-4 7v3h4M21 2v20"/>
        </svg>
      </div>
    )}
    {!isActive && (
      <div class="absolute inset-0 flex items-center justify-center">
        <span class="bg-white text-stone-500 text-sm font-medium px-4 py-1.5 rounded-full border border-stone-200 shadow-sm">Habis</span>
      </div>
    )}
  </div>

  <!-- Product info -->
  <div class="bg-white px-4 py-5 space-y-4">
    <div>
      <h1 class="text-xl font-bold text-stone-900 leading-snug">{product.category.name}</h1>
      <p class="text-stone-400 text-sm mt-0.5">{product.variant.label}</p>
      {product.description && (
        <p class="text-stone-500 text-sm mt-2 leading-relaxed">{product.description}</p>
      )}
      <div class="mt-3">
        {product.original_price && isActive && (
          <p class="text-stone-400 text-sm line-through">{formatRupiah(product.original_price)}</p>
        )}
        <p class={`font-bold text-2xl ${isActive ? 'text-stone-900' : 'text-stone-400'}`}>
          {formatRupiah(product.price)}
        </p>
      </div>
    </div>

    <!-- Habis notice -->
    {!isActive && (
      <div class="bg-stone-50 border border-stone-200 text-stone-500 text-sm text-center py-3 rounded-xl">
        Stok habis — hubungi kami untuk info ketersediaan
      </div>
    )}

    <!-- WA CTA -->
    {isActive && (
      <a
        href={waUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-center gap-2 w-full bg-stone-900 hover:bg-stone-800 text-white font-semibold py-3.5 rounded-2xl text-base transition-colors"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
          <path d="M12 0C5.373 0 0 5.373 0 12c0 2.118.55 4.107 1.512 5.832L.057 23.999l6.304-1.654A11.95 11.95 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 0 1-5.007-1.371l-.36-.213-3.736.979.999-3.648-.233-.374A9.818 9.818 0 1 1 12 21.818z"/>
        </svg>
        Pesan via WhatsApp
      </a>
    )}

    <!-- Delivery info -->
    <div class="bg-stone-50 rounded-xl p-4 space-y-2">
      <p class="text-stone-500 text-sm flex items-center gap-2.5">
        <span>🛵</span> GoSend / COD wilayah Yogyakarta
      </p>
      <p class="text-stone-500 text-sm flex items-center gap-2.5">
        <span>📦</span> Dikemas rapi agar tetap renyah
      </p>
    </div>

    <!-- Info Penting -->
    <div class="bg-amber-50 border border-amber-200 rounded-xl p-4">
      <p class="text-amber-800 text-xs font-semibold uppercase tracking-wide mb-3">Info Penting</p>
      <ul class="space-y-2">
        <li class="flex items-start gap-2 text-sm text-amber-900">
          <span class="mt-0.5 shrink-0 text-amber-500">•</span>
          COD area Sleman &amp; Kota
        </li>
        <li class="flex items-start gap-2 text-sm text-amber-900">
          <span class="mt-0.5 shrink-0 text-amber-500">•</span>
          Di luar area: GoSend / paket
        </li>
        <li class="flex items-start gap-2 text-sm text-amber-900">
          <span class="mt-0.5 shrink-0 text-amber-500">•</span>
          Minimum order H-1
        </li>
        <li class="flex items-start gap-2 text-sm text-amber-900">
          <span class="mt-0.5 shrink-0 text-amber-500">•</span>
          Varian khusus / anti-mainstream: H-7
        </li>
        <li class="flex items-start gap-2 text-sm text-amber-900">
          <span class="mt-0.5 shrink-0 text-amber-500">•</span>
          <span><span class="font-medium">Payment first</span> — order diproses setelah pembayaran dikonfirmasi</span>
        </li>
      </ul>
    </div>
  </div>

  <footer class="text-center text-stone-400 text-xs py-6 border-t border-stone-100">
    &copy; {new Date().getFullYear()} Nejemeyek — Peyek Khas Jogja
  </footer>
</BaseLayout>
