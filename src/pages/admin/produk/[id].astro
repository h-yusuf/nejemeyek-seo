---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import ImageUploader from '../../../components/admin/ImageUploader.astro';
import { getProductById, getCategories, getVariants, updateProduct } from '../../../lib/db';
import type { Product } from '../../../types';
import { formatRupiah } from '../../../lib/wa';

const { id } = Astro.params;
const db = Astro.locals.runtime.env.DB;

const [product, categories, variants] = await Promise.all([
  getProductById(db, id!),
  getCategories(db),
  getVariants(db),
]);

if (!product) return Astro.redirect('/admin/produk');

let saved = false;
let error = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const originalPriceRaw = form.get('original_price');

  const body = {
    id,
    category_id: form.get('category_id') as string,
    variant_id: form.get('variant_id') as string,
    price: Number(form.get('price')),
    original_price: originalPriceRaw && String(originalPriceRaw).trim() !== '' ? Number(originalPriceRaw) : null,
    description: form.get('description') ? String(form.get('description')).trim() : null,
    sort_order: Number(form.get('sort_order') ?? 0),
  };

  try {
    const { id: _id, ...updates } = body;
    await updateProduct(db, id!, updates as Partial<Omit<Product, 'id' | 'created_at' | 'updated_at' | 'category_id' | 'variant_id'>>);
    const webhook = Astro.locals.runtime.env.CF_PAGES_WEBHOOK;
    if (webhook) fetch(webhook, { method: 'POST' }).catch(() => {});
    saved = true;
  } catch (e: unknown) {
    error = e instanceof Error ? e.message : 'Gagal menyimpan perubahan';
  }
}
---

<AdminLayout title={`Edit: ${product.displayName}`}>
  <div class="flex items-center gap-3 mb-6">
    <a href="/admin/produk" class="text-stone-400 hover:text-stone-700 text-sm transition-colors">&#8592; Kembali</a>
    <span class="text-stone-200 text-xs">|</span>
    <h1 class="text-xl font-semibold truncate">{product.displayName}</h1>
    <span class={`ml-auto shrink-0 inline-block text-xs px-2 py-0.5 rounded-full ${product.is_active === 1 ? 'bg-green-100 text-green-700' : 'bg-stone-100 text-stone-500'}`}>
      {product.is_active === 1 ? 'Aktif' : 'Habis'}
    </span>
  </div>

  {saved && (
    <div class="bg-green-50 border border-green-200 text-green-700 rounded-lg px-4 py-3 mb-5 text-sm">
      Tersimpan!
    </div>
  )}
  {error && (
    <div class="bg-red-50 border border-red-200 text-red-700 rounded-lg px-4 py-3 mb-5 text-sm">
      {error}
    </div>
  )}

  <!-- Desktop 2-col / mobile stack -->
  <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-5">
    <!-- Left: form + danger zone -->
    <div class="space-y-4">
      <form method="POST" class="bg-white border border-stone-100 rounded-xl p-5 space-y-5">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-stone-700 mb-1.5">Kategori</label>
            <select name="category_id" class="w-full border border-stone-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-stone-400">
              {categories.map(c => (
                <option value={c.id} selected={c.id === product.category_id}>{c.name}</option>
              ))}
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-stone-700 mb-1.5">Variant</label>
            <select name="variant_id" class="w-full border border-stone-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-stone-400">
              {variants.map(v => (
                <option value={v.id} selected={v.id === product.variant_id}>{v.label}</option>
              ))}
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-stone-700 mb-1.5">Harga Jual (Rp)</label>
            <input
              type="number"
              name="price"
              value={product.price}
              min="1"
              required
              class="w-full border border-stone-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-stone-400"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-stone-700 mb-1.5">Harga Coret (Rp)</label>
            <input
              type="number"
              name="original_price"
              value={product.original_price ?? ''}
              min="1"
              class="w-full border border-stone-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-stone-400"
              placeholder="Kosongkan jika tidak ada"
            />
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-stone-700 mb-1.5">Deskripsi</label>
          <textarea
            name="description"
            rows="3"
            class="w-full border border-stone-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-stone-400 resize-none"
            placeholder="Deskripsi singkat produk (opsional)"
          >{product.description ?? ''}</textarea>
        </div>

        <div>
          <label class="block text-sm font-medium text-stone-700 mb-1.5">Urutan Tampil</label>
          <input
            type="number"
            name="sort_order"
            value={product.sort_order}
            class="w-28 border border-stone-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-stone-400"
          />
        </div>

        <div class="flex items-center gap-3 pt-1">
          <button type="submit" class="bg-stone-900 text-white font-medium py-2 px-5 rounded-lg hover:bg-stone-800 transition-colors text-sm">
            Simpan
          </button>
          <span class="text-xs text-stone-400">{formatRupiah(product.price)}</span>
        </div>
      </form>

      <!-- Danger zone -->
      <div class="bg-white border border-red-100 rounded-xl p-5">
        <p class="text-xs font-medium text-stone-500 uppercase tracking-wide mb-4">Zona Bahaya</p>
        <div class="flex gap-3 items-center flex-wrap">
          <button
            type="button"
            id="toggle-active-btn"
            data-id={product.id}
            data-active={product.is_active}
            class={`text-sm px-4 py-2 rounded-lg border font-medium transition-colors ${product.is_active === 1 ? 'border-amber-200 text-amber-700 hover:bg-amber-50' : 'border-green-200 text-green-700 hover:bg-green-50'}`}
          >
            {product.is_active === 1 ? 'Tandai Habis' : 'Aktifkan Kembali'}
          </button>
          <button
            type="button"
            id="delete-product-btn"
            data-id={product.id}
            data-name={product.displayName}
            class="text-sm px-4 py-2 rounded-lg border border-red-200 text-red-600 hover:bg-red-50 transition-colors font-medium"
          >
            Hapus Produk
          </button>
        </div>
        <p id="danger-error" class="hidden text-red-600 text-xs mt-3"></p>
      </div>
    </div>

    <!-- Right: image uploader -->
    <div class="bg-white border border-stone-100 rounded-xl p-5 self-start">
      <ImageUploader productId={product.id} currentImageUrl={product.image_url} />
    </div>
  </div>
</AdminLayout>

<script>
  // Toggle active/inactive
  document.getElementById('toggle-active-btn')?.addEventListener('click', async () => {
    const btn = document.getElementById('toggle-active-btn') as HTMLButtonElement;
    const newActive = Number(btn.dataset.active) === 1 ? 0 : 1;
    const res = await fetch('/admin/api/products', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: btn.dataset.id, is_active: newActive }),
    });
    if (res.ok) {
      window.location.reload();
    } else {
      const errEl = document.getElementById('danger-error')!;
      errEl.textContent = 'Gagal mengubah status produk';
      errEl.classList.remove('hidden');
    }
  });

  // Delete product
  document.getElementById('delete-product-btn')?.addEventListener('click', async () => {
    const btn = document.getElementById('delete-product-btn') as HTMLButtonElement;
    if (!window.confirm(`Hapus produk "${btn.dataset.name}"? Tindakan ini tidak dapat dibatalkan.`)) return;
    const res = await fetch('/admin/api/products', {
      method: 'DELETE',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: btn.dataset.id }),
    });
    if (res.ok) {
      window.location.href = '/admin/produk';
    } else {
      const errEl = document.getElementById('danger-error')!;
      errEl.textContent = 'Gagal menghapus produk';
      errEl.classList.remove('hidden');
    }
  });
</script>
