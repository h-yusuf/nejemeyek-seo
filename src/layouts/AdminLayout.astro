---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const path = Astro.url.pathname;

const navLinks = [
  { href: '/admin', label: 'Dashboard', exact: true },
  { href: '/admin/produk', label: 'Produk' },
  { href: '/admin/master', label: 'Master' },
];
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Nejemeyek Admin</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-stone-50 text-stone-900 font-sans min-h-screen">
    <!-- Top nav -->
    <nav class="bg-white border-b border-stone-200 sticky top-0 z-20">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 flex items-center h-14 gap-2">
        <!-- Brand -->
        <a href="/admin" class="font-semibold text-stone-900 shrink-0">
          Nejemeyek <span class="text-stone-400 font-normal text-sm">Admin</span>
        </a>

        <!-- Desktop nav links -->
        <div class="hidden sm:flex items-center gap-1 flex-1 ml-4">
          {navLinks.map(link => {
            const isActive = link.exact ? path === link.href : path.startsWith(link.href);
            return (
              <a
                href={link.href}
                class={`px-3 py-1.5 text-sm rounded-lg transition-colors ${isActive ? 'bg-stone-100 text-stone-900 font-medium' : 'text-stone-500 hover:text-stone-900 hover:bg-stone-50'}`}
              >
                {link.label}
              </a>
            );
          })}
        </div>

        <!-- Desktop right actions -->
        <div class="hidden sm:flex items-center gap-2 ml-auto shrink-0">
          <a
            href="/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-xs text-stone-400 hover:text-stone-600 border border-stone-200 rounded-lg px-3 py-1.5 transition-colors"
          >
            ↗ Lihat Toko
          </a>
          <form method="POST" action="/admin/api/logout">
            <button type="submit" class="text-xs text-stone-400 hover:text-stone-600 transition-colors px-2 py-1.5">
              Keluar
            </button>
          </form>
        </div>

        <!-- Mobile: spacer + hamburger -->
        <div class="sm:hidden flex-1"></div>
        <button
          id="nav-toggle"
          type="button"
          aria-label="Menu"
          aria-expanded="false"
          class="sm:hidden p-2 -mr-1 text-stone-500 hover:text-stone-900 transition-colors rounded-lg hover:bg-stone-50"
        >
          <!-- Hamburger icon -->
          <svg id="icon-menu" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="4" y1="6" x2="20" y2="6"/>
            <line x1="4" y1="12" x2="20" y2="12"/>
            <line x1="4" y1="18" x2="20" y2="18"/>
          </svg>
          <!-- Close icon -->
          <svg id="icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="hidden">
            <line x1="6" y1="6" x2="18" y2="18"/>
            <line x1="18" y1="6" x2="6" y2="18"/>
          </svg>
        </button>
      </div>

      <!-- Mobile menu (dropdown) -->
      <div id="nav-menu" class="sm:hidden hidden border-t border-stone-100 bg-white">
        <div class="px-4 py-3 space-y-1">
          {navLinks.map(link => {
            const isActive = link.exact ? path === link.href : path.startsWith(link.href);
            return (
              <a
                href={link.href}
                class={`block px-3 py-2.5 text-sm rounded-lg transition-colors ${isActive ? 'bg-stone-100 text-stone-900 font-medium' : 'text-stone-600 hover:bg-stone-50 hover:text-stone-900'}`}
              >
                {link.label}
              </a>
            );
          })}
        </div>
        <div class="px-4 py-3 border-t border-stone-100 flex items-center justify-between">
          <a
            href="/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-stone-400 hover:text-stone-600 transition-colors"
          >
            ↗ Lihat Toko
          </a>
          <form method="POST" action="/admin/api/logout">
            <button type="submit" class="text-sm text-stone-400 hover:text-stone-600 transition-colors">
              Keluar
            </button>
          </form>
        </div>
      </div>
    </nav>

    <main class="max-w-5xl mx-auto px-4 sm:px-6 py-6">
      <slot />
    </main>
  </body>
</html>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-menu');
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    if (isOpen) {
      menu?.classList.add('hidden');
      iconMenu?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
    } else {
      menu?.classList.remove('hidden');
      iconMenu?.classList.add('hidden');
      iconClose?.classList.remove('hidden');
      toggle.setAttribute('aria-expanded', 'true');
    }
  });
</script>
