---
import type { Category } from '../types';

interface Props {
  categories: Category[];
}
const { categories } = Astro.props;
---

<div class="sticky top-0 z-10 bg-white border-b border-stone-100 px-4 py-3">
  <div class="flex gap-2 overflow-x-auto pb-0.5 scrollbar-none" id="cat-tabs">
    <button type="button" data-cat="semua" class="cat-tab cat-active flex-shrink-0 px-4 py-2 rounded-full text-sm font-semibold">
      Semua
    </button>
    {categories.map(cat => (
      <button type="button" data-cat={cat.id} class="cat-tab cat-inactive flex-shrink-0 px-4 py-2 rounded-full text-sm font-medium">
        {cat.name}
      </button>
    ))}
  </div>
</div>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.cat-tab');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const cat = tab.dataset.cat!;

      tabs.forEach(t => {
        t.classList.remove('cat-active');
        t.classList.add('cat-inactive');
      });
      tab.classList.remove('cat-inactive');
      tab.classList.add('cat-active');

      document.dispatchEvent(new CustomEvent('cat:change', { detail: cat }));
    });
  });
</script>

<style>
  .scrollbar-none { scrollbar-width: none; }
  .scrollbar-none::-webkit-scrollbar { display: none; }

  .cat-active {
    background-color: #1c1c1c;
    color: #ffffff;
  }
  .cat-inactive {
    background-color: #ffffff;
    color: #57534e;
    border: 1px solid #e7e5e4;
  }
</style>
