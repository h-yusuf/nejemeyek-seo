+  it('converts to URL-safe slug', () => {
+    expect(slugify('Peyek Rebon')).toBe('peyek-rebon');
+  });
+  it('strips special characters', () => {
+    expect(slugify('Peyek & Teri!')).toBe('peyek-teri');
+  });
