---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getAllProducts, getCategories, getVariants, getViewStats } from '../../lib/db';

const db = Astro.locals.runtime.env.DB;
const [products, categories, variants, views] = await Promise.all([
  getAllProducts(db),
  getCategories(db),
  getVariants(db),
  getViewStats(db),
]);

const active = products.filter(p => p.is_active === 1).length;
const inactive = products.length - active;
const noPhoto = products.filter(p => !p.image_url).length;
const noDesc = products.filter(p => !p.description).length;
const seoReady = products.filter(p => p.image_url && p.description).length;

// Build 7-day chart data (fill missing dates with 0)
const todayStr = new Date().toISOString().split('T')[0];
const dailyMap = new Map(views.daily.map(d => [d.date, d.count]));
const chartData = Array.from({ length: 7 }, (_, i) => {
  const d = new Date(Date.now() - (6 - i) * 86400000);
  const dateStr = d.toISOString().split('T')[0];
  const dayLabel = d.toLocaleDateString('id-ID', { weekday: 'short' });
  const dateLabel = d.toLocaleDateString('id-ID', { day: 'numeric', month: 'short' });
  return {
    date: dateStr,
    count: dailyMap.get(dateStr) ?? 0,
    dayLabel,
    dateLabel,
    isToday: dateStr === todayStr,
  };
});
const maxCount = Math.max(...chartData.map(d => d.count), 1);

// Resolve top page names
const topPages = views.topPages.map(row => {
  if (row.page === '/') return { label: 'Beranda', page: row.page, total: row.total };
  const match = row.page.match(/^\/produk\/(.+)$/);
  if (match) {
    const product = products.find(p => p.id === match[1]);
    return { label: product?.displayName ?? row.page, page: row.page, total: row.total };
  }
  return { label: row.page, page: row.page, total: row.total };
});
---

<AdminLayout title="Dashboard">
  <h1 class="text-xl font-semibold mb-6">Dashboard</h1>

  <!-- Kunjungan + chart -->
  <section class="mb-6">
    <h2 class="text-xs font-medium text-stone-400 uppercase tracking-wide mb-3">Kunjungan</h2>
    <div class="bg-white border border-stone-100 rounded-xl p-5">
      <!-- Stats row -->
      <div class="flex gap-6 mb-5">
        <div>
          <p class="text-3xl font-bold text-stone-900">{views.today.toLocaleString('id-ID')}</p>
          <p class="text-xs text-stone-400 mt-0.5">Hari ini</p>
        </div>
        <div class="w-px bg-stone-100"></div>
        <div>
          <p class="text-3xl font-bold text-stone-900">{views.week.toLocaleString('id-ID')}</p>
          <p class="text-xs text-stone-400 mt-0.5">7 hari terakhir</p>
        </div>
      </div>

      <!-- Bar chart -->
      <div class="flex items-end gap-1.5 h-28" aria-label="Grafik kunjungan 7 hari">
        {chartData.map(d => {
          const heightPct = Math.max(3, Math.round(d.count / maxCount * 100));
          return (
            <div class="flex-1 flex flex-col items-center gap-1.5 group relative h-full justify-end">
              <!-- Tooltip -->
              <div class="absolute bottom-full mb-1.5 left-1/2 -translate-x-1/2 opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-10">
                <div class="bg-stone-900 text-white text-xs rounded-lg px-2 py-1 whitespace-nowrap">
                  {d.count} · {d.dateLabel}
                </div>
                <div class="w-2 h-2 bg-stone-900 rotate-45 mx-auto -mt-1"></div>
              </div>
              <!-- Bar -->
              <div
                class={`w-full rounded-t-sm transition-all ${d.isToday ? 'bg-stone-900' : 'bg-stone-200 group-hover:bg-stone-400'}`}
                style={`height: ${heightPct}%`}
              ></div>
              <!-- Label -->
              <p class={`text-xs leading-none ${d.isToday ? 'text-stone-900 font-semibold' : 'text-stone-400'}`}>
                {d.dayLabel}
              </p>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Produk stats -->
  <section class="mb-6">
    <h2 class="text-xs font-medium text-stone-400 uppercase tracking-wide mb-3">Produk</h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      <div class="bg-white border border-stone-100 rounded-xl p-4">
        <p class="text-3xl font-bold text-stone-900">{active}</p>
        <p class="text-xs text-stone-400 mt-1">Aktif</p>
      </div>
      <div class="bg-white border border-stone-100 rounded-xl p-4">
        <p class="text-3xl font-bold text-stone-900">{inactive}</p>
        <p class="text-xs text-stone-400 mt-1">Habis</p>
      </div>
      <div class="bg-white border border-stone-100 rounded-xl p-4">
        <p class="text-3xl font-bold text-stone-900">{categories.length}</p>
        <p class="text-xs text-stone-400 mt-1">Kategori</p>
      </div>
      <div class="bg-white border border-stone-100 rounded-xl p-4">
        <p class="text-3xl font-bold text-stone-900">{variants.length}</p>
        <p class="text-xs text-stone-400 mt-1">Variant</p>
      </div>
    </div>
  </section>

  <!-- SEO completeness + Top pages -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-6">
    <!-- SEO Completeness -->
    <section>
      <h2 class="text-xs font-medium text-stone-400 uppercase tracking-wide mb-3">Kelengkapan SEO</h2>
      <div class="bg-white border border-stone-100 rounded-xl p-4 space-y-3">
        <div class="flex items-center justify-between">
          <span class="text-sm text-stone-600">Produk siap Google</span>
          <span class="text-sm font-semibold text-stone-900">{seoReady} / {products.length}</span>
        </div>
        <div class="w-full bg-stone-100 rounded-full h-1.5">
          <div
            class="bg-stone-900 h-1.5 rounded-full"
            style={`width: ${products.length ? Math.round(seoReady / products.length * 100) : 0}%`}
          ></div>
        </div>
        {noPhoto > 0 && (
          <div class="flex items-center justify-between text-sm">
            <span class="text-amber-700">Tanpa foto</span>
            <a href="/admin/produk" class="font-medium text-amber-700 hover:underline">{noPhoto} produk →</a>
          </div>
        )}
        {noDesc > 0 && (
          <div class="flex items-center justify-between text-sm">
            <span class="text-amber-700">Tanpa deskripsi</span>
            <a href="/admin/produk" class="font-medium text-amber-700 hover:underline">{noDesc} produk →</a>
          </div>
        )}
        {noPhoto === 0 && noDesc === 0 && products.length > 0 && (
          <p class="text-sm text-green-700">Semua produk sudah lengkap ✓</p>
        )}
      </div>
    </section>

    <!-- Top pages -->
    <section>
      <h2 class="text-xs font-medium text-stone-400 uppercase tracking-wide mb-3">Halaman Terpopuler</h2>
      <div class="bg-white border border-stone-100 rounded-xl overflow-hidden">
        {topPages.length === 0 ? (
          <p class="text-sm text-stone-400 p-4">Belum ada data kunjungan.</p>
        ) : (
          <ul class="divide-y divide-stone-50">
            {topPages.map((row, i) => (
              <li class="flex items-center gap-3 px-4 py-2.5">
                <span class="text-xs text-stone-300 w-4 shrink-0 text-right">{i + 1}</span>
                <span class="text-sm text-stone-700 truncate flex-1">{row.label}</span>
                <span class="text-sm font-semibold text-stone-900 shrink-0">{row.total.toLocaleString('id-ID')}</span>
              </li>
            ))}
          </ul>
        )}
      </div>
    </section>
  </div>

  <!-- Quick actions -->
  <div class="flex gap-3 flex-wrap">
    <a href="/admin/produk/new" class="bg-stone-900 text-white text-sm font-medium py-2 px-4 rounded-lg hover:bg-stone-800 transition-colors">
      + Tambah Produk
    </a>
    <a href="/admin/produk" class="border border-stone-200 text-stone-600 text-sm font-medium py-2 px-4 rounded-lg hover:bg-stone-50 transition-colors">
      Kelola Produk
    </a>
    <a href="/admin/master" class="border border-stone-200 text-stone-600 text-sm font-medium py-2 px-4 rounded-lg hover:bg-stone-50 transition-colors">
      Kategori & Variant
    </a>
  </div>
</AdminLayout>
