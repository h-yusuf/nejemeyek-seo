---
import { formatRupiah, buildWaOrderUrl } from '../lib/wa';
import type { ProductWithDetails } from '../types';

interface Props {
  product: ProductWithDetails;
  waNumber?: string;
}

const { product, waNumber } = Astro.props;
const waUrl = waNumber ? buildWaOrderUrl({ displayName: product.displayName, qty: 1, waNumber }) : null;
const isActive = product.is_active === 1;
---

<div
  data-product-cat={product.category_id}
  data-product-name={product.displayName.toLowerCase()}
  class="bg-white rounded-2xl overflow-hidden flex flex-col"
>
  <!-- Image -->
  <a href={`/produk/${product.id}`} class="relative bg-stone-100 block aspect-square">
    {product.image_url ? (
      <img
        src={product.image_url}
        alt={product.displayName}
        class={`w-full h-full object-cover ${!isActive ? 'opacity-40' : ''}`}
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center">
        <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#d1d5db" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 2v4c0 1.1.9 2 2 2s2-.9 2-2V2M5 8v14M3 5h4"/>
          <path d="M21 2c-2.5 1-4 3.5-4 7v3h4M21 2v20"/>
        </svg>
      </div>
    )}
    {!isActive && (
      <div class="absolute inset-0 flex items-center justify-center">
        <span class="bg-white text-stone-400 text-xs font-medium px-3 py-1 rounded-full border border-stone-200 shadow-sm">Habis</span>
      </div>
    )}
  </a>

  <!-- Info -->
  <div class="px-3 pt-3 pb-3 flex flex-col flex-1">
    <p class={`font-semibold text-sm leading-snug ${isActive ? 'text-stone-900' : 'text-stone-400'}`}>
      {product.category.name}
    </p>
    <p class="text-stone-400 text-xs mt-0.5">{product.variant.label}</p>
    {product.description && (
      <p class="text-stone-400 text-xs mt-1 leading-relaxed line-clamp-2">{product.description}</p>
    )}

    <div class="mt-auto">
      {product.original_price && isActive && (
        <p class="text-stone-400 text-xs line-through mt-2">{formatRupiah(product.original_price)}</p>
      )}
      <p class={`font-bold text-base ${isActive ? 'text-stone-900' : 'text-stone-400'} ${!product.original_price ? 'mt-2' : ''}`}>
        {formatRupiah(product.price)}
      </p>
    </div>

    <!-- Button -->
    {isActive && waUrl ? (
      <a
        href={waUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-3 flex items-center justify-center gap-1 w-full border border-stone-200 text-stone-700 text-sm font-medium py-2.5 rounded-xl hover:bg-stone-50 transition-colors"
      >
        + Pesan
      </a>
    ) : (
      <div class="mt-3 flex items-center justify-center w-full text-stone-300 text-sm py-2.5">
        + Pesan
      </div>
    )}
  </div>
</div>
